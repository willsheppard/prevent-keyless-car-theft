{# Shared "what the coloured labels mean" legend, used by both the homepage and
   brand pages. Single source of truth for the tag explanations. #}
<div class="legend">
  <h2>What the coloured labels mean</h2>
  <div class="legend-grid">
    <div class="legend-item">
      <span class="tag auto">Automatic</span>
      <p><strong>Best — nothing to remember</strong>The key fob switches itself off when left still. Protection is always on.</p>
    </div>
    <div class="legend-item">
      <span class="tag temp">Temporary</span>
      <p><strong>Turn off when you choose</strong>Disable keyless entry overnight or on holiday. You repeat it each time.</p>
    </div>
    <div class="legend-item">
      <span class="tag perm">Permanent</span>
      <p><strong>Switch it off for good</strong>Disable keyless entry completely if you never use it.</p>
    </div>
  </div>
</div>
