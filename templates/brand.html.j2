{% extends "base.html.j2" %}
{% from "macros.html.j2" import render_steps %}

{% block head_extra %}
{% for blob in jsonld %}
<script type="application/ld+json">{{ blob|safe }}</script>
{% endfor %}
<style>
  .brand-hero h1 { text-transform: none; }
  .brand-back { margin-top: 14px; }
  .brand-back a { color: #fff; font-weight: 600; }
  .breadcrumb { font-size: 14px; color: var(--muted); margin: 4px 0 18px; }
  .breadcrumb a { color: var(--green); }
  .brand-methods .method:first-child { margin-top: 4px; }
  .models-note { font-size: 14px; color: var(--muted); margin-top: 18px; }
</style>
{% endblock %}

{% block header %}
<header class="hero brand-hero">
  <div class="wrap">
    <span class="badge">Free · No products to buy</span>
    <h1>How to disable keyless entry on a {{ brand }}</h1>
    <p class="subtitle">{{ subtitle }}</p>
    <p class="brand-back"><a href="/#finder">← Search a different car</a></p>
  </div>
</header>
{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a> › <span aria-current="page">{{ brand }}</span>
</nav>

<section class="content">
  <h2>Why your {{ brand }} is at risk</h2>
  {{ intro_html|safe }}
</section>

<section class="content">
  <h2>How to disable it on your {{ brand }}</h2>
  <div class="brand-methods">
    {% for step_set in methods %}
    {{ render_steps(step_set) }}
    {% endfor %}
  </div>
  <p class="models-note">Applies across {{ brand }} models including {{ aliases_text }}.</p>
</section>

<div class="legend">
  <h2>What the coloured labels mean</h2>
  <div class="legend-grid">
    <div class="legend-item"><span class="tag auto">Automatic</span><p><strong>Best — nothing to remember</strong>The key fob switches itself off when left still.</p></div>
    <div class="legend-item"><span class="tag temp">Temporary</span><p><strong>Turn off when you choose</strong>Disable it overnight or on holiday; you repeat it each time.</p></div>
    <div class="legend-item"><span class="tag perm">Permanent</span><p><strong>Switch it off for good</strong>Disable keyless entry completely.</p></div>
  </div>
</div>

<section class="content">
  <h2>Common questions</h2>
  {% for faq in faqs %}
  <details class="faq">
    <summary>{{ faq.q }}</summary>
    <div class="faq-body"><p>{{ faq.a }}</p></div>
  </details>
  {% endfor %}
</section>
{% endblock %}
