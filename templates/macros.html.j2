{# render_instruction(instruction): renders one way to disable keyless entry: a
   tagged block with optional intro text, an ordered/unordered step list, labelled
   sub-procedures, and notes. TYPE_LABEL is a Jinja global set in build.py.
   Standalone "info" notes live in a separate car.info field and are rendered by
   the page, not here. #}
{% macro render_instruction(instruction) %}
<div class="instruction">
  <div class="instruction-head">
    <span class="tag {{ instruction.type }}">{{ TYPE_LABEL[instruction.type] }}</span>
    {% if instruction.unverified %}<span class="tag unverified">Unverified</span>{% endif %}
    {% if instruction.models %}<span class="instruction-models">{{ instruction.models }}</span>{% endif %}
  </div>
  {% if instruction.text %}<p>{{ instruction.text|safe }}</p>{% endif %}
  {% if instruction.steps %}
  {# Numbered when order matters: permanent changes, or more than two steps. #}
  {% set ordered = (instruction.type == 'perm') or (instruction.steps|length > 2) %}
  {% if ordered %}<ol>{% else %}<ul>{% endif %}
    {% for step in instruction.steps %}<li>{{ step|safe }}</li>{% endfor %}
  {% if ordered %}</ol>{% else %}</ul>{% endif %}
  {% endif %}
  {% if instruction.sub %}
  {# Labelled sub-procedures, e.g. "To re-enable:" followed by its own steps. #}
  {% for sub in instruction.sub %}
  <p><strong>{{ sub.label }}:</strong></p>
  <ul>{% for sub_step in sub.steps %}<li>{{ sub_step|safe }}</li>{% endfor %}</ul>
  {% endfor %}
  {% endif %}
  {% if instruction.notes %}
  {% for note in instruction.notes %}<p class="note">{{ note|safe }}</p>{% endfor %}
  {% endif %}
</div>
{% endmacro %}

{# render_card(card): one collapsible brand card for the homepage finder. Mirrors
   cardHTML()/bodyHTML()/tagsFor() in js/app.js, which now only filter/expand these
   pre-rendered cards (no client-side rendering). `card` is a dict prepared in
   build.py: idx, name, initials, search, unknown, tag_types, instructions, info. #}
{% macro render_card(card) %}
<div class="card" id="brand-{{ card.slug }}" data-idx="{{ card.idx }}" data-search="{{ card.search }}">
  <div class="card-top">
  <button class="card-head" aria-expanded="false" aria-controls="body-{{ card.idx }}">
    <span class="brand-logo" aria-hidden="true">{{ card.initials }}</span>
    <span class="brand-meta">
      <span class="brand-name">{{ card.name }}</span>
      <span class="brand-tags">
        {% if card.unknown %}<span class="tag none">Help needed</span>
        {% else %}{% for type in card.tag_types %}<span class="tag {{ type }}">{{ TYPE_LABEL[type] }}</span>{% endfor %}{% endif %}
      </span>
    </span>
    <svg class="chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </button>
  <button type="button" class="card-link" data-link="{{ card.link }}" aria-label="Copy link to {{ card.name }}" title="Copy link to {{ card.name }}">
    <svg class="ico ico-link" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
    <svg class="ico ico-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
  </button>
  </div>
  <div class="card-body" id="body-{{ card.idx }}">
    {% if card.unknown %}
    <p class="unknown-body">We don't yet have confirmed instructions for {{ card.name }}. Many {{ card.name }} models do support disabling keyless entry -- check your owner's manual under "keyless" or "passive entry".<br><a class="contribute-link" href="#contribute">Know how? Help us add {{ card.name }} →</a></p>
    {% for note in card.info %}<p class="note">{{ note|safe }}</p>{% endfor %}
    {% else %}
    {% for instruction in card.instructions %}{{ render_instruction(instruction) }}{% endfor %}
    {% for note in card.info %}<p class="note">{{ note|safe }}</p>{% endfor %}
    {% endif %}
  </div>
</div>
{% endmacro %}
